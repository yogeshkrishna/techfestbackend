# ============================================================
# Tech Fest Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL (Prisma) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/techfest?schema=public

# --- Redis ---
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Use a long, random string (at least 64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string
# Token expiry duration (e.g. "7d", "24h")
JWT_EXPIRES_IN=7d

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
# Webhook secret for verifying Razorpay POST callbacks
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# --- SMTP (Nodemailer) ---
# For development, use a service like Mailtrap (mailtrap.io)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# From address that appears in sent emails
SMTP_FROM=noreply@techfest.example.com

# --- QR / HMAC ---
# Secret used to HMAC-sign QR tokens. Must be kept secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_HMAC_SECRET=replace_with_a_32_char_random_hex_string

# --- Seed (Host Account) ---
# Credentials for the seeded HOST user. Change before deploying.
SEED_HOST_EMAIL=host@techfest.example.com
SEED_HOST_NAME=Tech Fest Host
SEED_HOST_PHONE=+910000000000
SEED_HOST_INSTITUTION=Tech Fest Organizing Committee
